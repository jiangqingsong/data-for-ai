# ============================================
# RAG 知识库问答系统 — 配置说明
# ============================================
# 敏感信息（API Key）不在本文件中存储。
# 统一配置文件: E:/AI-env/llm/config.json
#
# 配置格式:
#   {
#     "deepseek": {
#       "api_key": "你的火山引擎 API Key",
#       "base_url": "https://ark.cn-beijing.volces.com/api/compatible",
#       "model": "deepseek-chat"
#     }
#   }
#
# 非敏感参数可通过系统环境变量覆盖:
#   CHROMA_PERSIST_DIR  - Chroma 存储路径 (默认: ./data/chroma_db)
#   RETRIEVER_TOP_K     - 检索数量 (默认: 4)
#   CHUNK_SIZE          - 分块大小 (默认: 1000)
#   CHUNK_OVERLAP       - 分块重叠 (默认: 200)
# ============================================

# Chroma
CHROMA_PERSIST_DIR=./data/chroma_db

# Model
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Retriever
RETRIEVER_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
