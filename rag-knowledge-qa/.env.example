# ============================================
# RAG 知识库问答系统 — 环境变量配置说明
# ============================================
# 不在本文件中存储敏感信息！
# 请在你的系统环境变量中配置以下变量：
#
#   Windows (PowerShell):
#     [Environment]::SetEnvironmentVariable('DEEPSEEK_API_KEY', 'sk-xxx', 'User')
#     [Environment]::SetEnvironmentVariable('DEEPSEEK_BASE_URL', 'https://ark.cn-beijing.volces.com/api/compatible', 'User')
#
#   Windows (CMD, 管理员):
#     setx DEEPSEEK_API_KEY "sk-xxx"
#     setx DEEPSEEK_BASE_URL "https://ark.cn-beijing.volces.com/api/compatible"
#
#   Linux/Mac:
#     export DEEPSEEK_API_KEY=sk-xxx
#     export DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/compatible
#
# ============================================

# DeepSeek API (火山引擎)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/compatible

# Chroma
CHROMA_PERSIST_DIR=./data/chroma_db

# Model
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Retriever
RETRIEVER_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
